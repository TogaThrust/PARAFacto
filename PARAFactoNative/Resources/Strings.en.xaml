    <sys:String x:Key="Technical.Smtp.UseSmtpCheck" xmlns:sys="clr-namespace:System;assembly=mscorlib">Prefer SMTP (Gmail or other) over Outlook</sys:String>
    <sys:String x:Key="Technical.Smtp.Hint" xmlns:sys="clr-namespace:System;assembly=mscorlib">Fill in host (e.g. smtp.gmail.com), username and app password. If unchecked: Outlook first; if Outlook fails or is missing, SMTP is used automatically when these fields are complete.</sys:String>
    <sys:String x:Key="Technical.Smtp.DbBackupRecipientLabel" xmlns:sys="clr-namespace:System;assembly=mscorlib">Database backup email:</sys:String>
