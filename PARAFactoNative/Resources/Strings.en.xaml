    <sys:String x:Key="Agenda.DayWorkdayOverrideHint" xmlns:sys="clr-namespace:System;assembly=mscorlib">Shift + double-click the date: start/end of workday for that day (month/week). Day view: Shift + double-click the schedule list.</sys:String>
    <sys:String x:Key="Agenda.DayLunchOverrideHint" xmlns:sys="clr-namespace:System;assembly=mscorlib">Double-click the date (month/week) or the day list: lunch break for that date, even when no yellow bar is shown. Double-click the yellow lunch line: same.</sys:String>
