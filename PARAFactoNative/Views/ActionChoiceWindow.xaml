<Window x:Class="PARAFactoNative.Views.ActionChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmation"
        Width="860"
        MinWidth="760"
        MaxWidth="980"
        SizeToContent="Height"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1"
                Padding="0,0,0,16"
                Margin="0,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="280">
                <TextBlock x:Name="MessageText"
                           Style="{StaticResource DialogMessageTextBlock}"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="SecondaryButton"
                    Style="{StaticResource DialogChoiceButton}"
                    Margin="0,0,8,0"
                    Click="Secondary_OnClick"/>
            <Button x:Name="PrimaryButton"
                    Style="{StaticResource DialogPrimaryChoiceButton}"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Primary_OnClick"/>
            <Button x:Name="CancelButton"
                    Style="{StaticResource DialogChoiceButton}"
                    IsCancel="True"
                    Click="Cancel_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
