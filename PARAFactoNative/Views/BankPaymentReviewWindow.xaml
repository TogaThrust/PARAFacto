<Window x:Class="PARAFactoNative.Views.BankPaymentReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Association manuelle d'un virement"
        Width="900"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="16"
                   FontWeight="Bold"
                   Text="Virement à traiter manuellement"/>

        <Border Grid.Row="1" Margin="0,10,0,10" Padding="10" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <TextBlock x:Name="ReasonText" FontWeight="Bold" TextWrapping="Wrap"/>
                <TextBlock x:Name="PaymentText" Margin="0,6,0,0" TextWrapping="Wrap"/>
                <TextBlock x:Name="CommunicationText" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock VerticalAlignment="Center" Text="Rechercher facture / patient / montant :"/>
            <TextBox x:Name="SearchBox" Width="320" Margin="10,0,0,0" TextChanged="SearchBox_TextChanged"/>
        </StackPanel>

        <DataGrid x:Name="CandidatesGrid"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  MouseDoubleClick="CandidatesGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Facture" Binding="{Binding InvoiceNo}" Width="130"/>
                <DataGridTextColumn Header="Communication" Binding="{Binding PaymentReference}" Width="160"/>
                <DataGridTextColumn Header="Destinataire" Binding="{Binding Recipient}" Width="*"/>
                <DataGridTextColumn Header="Solde" Binding="{Binding BalanceEuro}" Width="95"/>
                <DataGridTextColumn Header="Total" Binding="{Binding TotalEuro}" Width="95"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Width="180" Margin="0,0,8,0" Content="Associer à la sélection" Click="Apply_Click"/>
            <Button Width="190" Margin="0,0,8,0" Content="Passer au paiement suivant" Click="Skip_Click"/>
            <Button Width="120" Content="Arrêter l'import" Click="Stop_Click"/>
        </StackPanel>
    </Grid>
</Window>
