<Window x:Class="PARAFactoNative.Views.UnavailabilityRescheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifier l'indisponibilité"
        Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="IntroLine" Style="{StaticResource DialogMessageTextBlock}"/>
        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Style="{StaticResource DialogSectionHeaderTextBlock}" Margin="0,0,0,4" Text="Heure de début"/>
                <ComboBox x:Name="StartCombo" IsEditable="False" SelectionChanged="StartCombo_OnSelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Style="{StaticResource DialogSectionHeaderTextBlock}" Margin="0,0,0,4" Text="Heure de fin"/>
                <ComboBox x:Name="EndCombo" IsEditable="False"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Style="{StaticResource DialogSectionHeaderTextBlock}" Margin="0,0,0,4" Text="Raison (optionnel)"/>
            <TextBox x:Name="ReasonBox" AcceptsReturn="False" MaxLength="200"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource DialogChoiceButton}" Margin="0,0,8,0" Content="Annuler" IsCancel="True"/>
            <Button Style="{StaticResource DialogPrimaryChoiceButton}" Content="OK" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
