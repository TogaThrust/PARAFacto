<Window x:Class="PARAFactoNative.Views.LunchRescheduleDayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reporter le lunch (ce jour uniquement)"
        MinHeight="420" Height="440" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="DateLabel" Grid.Row="0" Style="{StaticResource DialogCaptionTextBlock}" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource DialogMessageTextBlock}"
                   Text="Cliquez une ligne dans chaque liste (heure et durée). La plage s’affichera en jaune dans l’agenda pour cette date seulement."/>
        <!-- ListBox : pas de popup séparé (souvent derrière une fenêtre modale avec Owner), contrairement au ComboBox. -->
        <Grid Grid.Row="2" Margin="0,14,0,0" MinHeight="200">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Style="{StaticResource DialogSectionHeaderTextBlock}" Margin="0,0,0,4" Text="Heure de début"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Background="White">
                    <ListBox x:Name="StartList" MinHeight="180" MaxHeight="220"
                             BorderThickness="0" Padding="2"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="False"
                             ScrollViewer.CanContentScroll="False"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Style="{StaticResource DialogSectionHeaderTextBlock}" Margin="0,0,0,4" Text="Durée (minutes)"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Background="White">
                    <ListBox x:Name="DurationList" MinHeight="180" MaxHeight="220"
                             BorderThickness="0" Padding="2"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="False"
                             ScrollViewer.CanContentScroll="False"/>
                </Border>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource DialogChoiceButton}" Margin="0,0,8,0" Content="Annuler" IsCancel="True"/>
            <Button Style="{StaticResource DialogPrimaryChoiceButton}" Content="Enregistrer" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
