<Window x:Class="PARAFactoNative.Views.TarifEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nouveau tarif" Height="260" Width="420" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource DialogCaptionTextBlock}"
                   x:Name="TitleText" Text="Nouveau tarif"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DialogFieldLabelTextBlock}" Margin="0,10,8,0" Text="Libellé :"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" x:Name="LabelBox"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DialogFieldLabelTextBlock}" Margin="0,10,8,0" Text="Part patient (€) :"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Width="100" HorizontalAlignment="Left" x:Name="PartPatientBox"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DialogFieldLabelTextBlock}" Margin="0,10,8,0" Text="Part mutuelle (€) :"/>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Width="100" HorizontalAlignment="Left" x:Name="PartMutuelleBox"/>

        <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0" Content="Actif" x:Name="ActiveCheck" IsChecked="True"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource DialogChoiceButton}" Margin="0,0,8,0" Content="Annuler" IsCancel="True"/>
            <Button Style="{StaticResource DialogPrimaryChoiceButton}" Content="Enregistrer" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
