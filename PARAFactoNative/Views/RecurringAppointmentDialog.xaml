<Window x:Class="PARAFactoNative.Views.RecurringAppointmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encodage récurrent"
        Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" MaxHeight="120" ClipToBounds="True" Margin="0,0,0,0">
            <ScrollViewer Style="{StaticResource DialogFormScrollViewer}">
                <TextBlock Style="{StaticResource DialogMessageTextBlock}"
                           Text="À partir de la date et de l’heure du formulaire agenda, les rendez-vous seront créés selon la répétition choisie. Les dimanches, jours fériés BE et créneaux hors plage de journée sont ignorés. Un chevauchement avec un autre RDV, une indisponibilité ou le lunch est traité comme un conflit : vous pourrez déplacer la récurrence, le RDV existant, l’indisponibilité ou le lunch (ce jour), ou ignorer le créneau."/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Margin="0,0,0,4" Style="{StaticResource DialogSectionHeaderTextBlock}" Text="Répétition"/>
            <ComboBox x:Name="PatternCombo" DisplayMemberPath="Label" SelectionChanged="PatternCombo_OnSelectionChanged"/>

            <StackPanel x:Name="WeekdayPanel" Margin="0,10,0,0" Visibility="Collapsed">
                <TextBlock Style="{StaticResource DialogSectionHeaderTextBlock}" Margin="0,0,0,4" Text="Jour de la semaine"/>
                <ComboBox x:Name="WeekdayCombo" DisplayMemberPath="Label"/>
            </StackPanel>

            <StackPanel x:Name="DayOfMonthPanel" Margin="0,10,0,0" Visibility="Collapsed">
                <TextBlock Style="{StaticResource DialogSectionHeaderTextBlock}" Margin="0,0,0,4" Text="Jour du mois (1–31)"/>
                <ComboBox x:Name="DayOfMonthCombo" Width="80" HorizontalAlignment="Left"/>
            </StackPanel>

            <StackPanel Margin="0,14,0,0">
                <TextBlock Style="{StaticResource DialogSectionHeaderTextBlock}" Margin="0,0,0,8" Text="Fin de la série"/>
                <RadioButton x:Name="EndByDateRadio" GroupName="End" Content="Jusqu’à la date :" IsChecked="True" Margin="0,0,0,6"/>
                <DatePicker x:Name="EndDatePick" Margin="24,0,0,10"/>
                <RadioButton x:Name="EndByCountRadio" GroupName="End" Content="Nombre de rendez-vous :" Margin="0,0,0,6"/>
                <ComboBox x:Name="CountCombo"
                          Width="80"
                          MinHeight="28"
                          HorizontalAlignment="Left"
                          Margin="24,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource DialogChoiceButton}" Margin="0,0,8,0" Content="Annuler" IsCancel="True"/>
            <Button Style="{StaticResource DialogPrimaryChoiceButton}" Content="OK" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
