<UserControl x:Class="PARAFactoNative.Views.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="960"
             Background="#FAFBFC">

    <UserControl.Resources>
        <Style x:Key="HelpCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style x:Key="HelpPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HelpSecondaryButton" TargetType="Button" BasedOn="{StaticResource HelpPrimaryButton}">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd2" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" BorderBrush="#CBD5E1" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd2" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd2" Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="0,6"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="28,24,28,32">
        <StackPanel MaxWidth="1040" HorizontalAlignment="Stretch">

            <!-- En-tête -->
            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="{DynamicResource Help.Hero.Title}"
                           FontSize="28" FontWeight="Bold" Foreground="#0F172A" LineHeight="34"/>
                <TextBlock Text="{DynamicResource Help.Hero.Subtitle}"
                           FontSize="14" Foreground="#64748B" TextWrapping="Wrap" Margin="0,10,0,0" LineHeight="22"/>
            </StackPanel>

            <!-- Cartes e-mail + chat -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource HelpCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="4" Height="22" CornerRadius="2" Background="#2563EB" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource Help.Email.Title}" FontSize="17" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource Help.Email.Body}" TextWrapping="Wrap" Foreground="#475569" FontSize="13" LineHeight="21" Margin="0,0,0,14"/>
                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#1E40AF" FontFamily="Cascadia Mono,Consolas,Segoe UI" Text="{DynamicResource Help.Email.Address}"/>
                        <Button Content="{DynamicResource Help.Email.Button}"
                                Command="{Binding OpenHelpdeskEmailCommand}"
                                Style="{StaticResource HelpPrimaryButton}"
                                Margin="0,18,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource HelpCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="4" Height="22" CornerRadius="2" Background="#7C3AED" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource Help.Chat.Title}" FontSize="17" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Background="#F5F3FF" CornerRadius="8" Padding="10,6" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource Help.Chat.Badge}" FontSize="12" FontWeight="SemiBold" Foreground="#5B21B6"/>
                        </Border>
                        <TextBlock Text="{DynamicResource Help.Chat.Body}" TextWrapping="Wrap" Foreground="#475569" FontSize="13" LineHeight="21"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- FAQ -->
            <Border Style="{StaticResource HelpCard}" Margin="0,4,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Width="4" Height="22" CornerRadius="2" Background="#0D9488" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="{DynamicResource Help.Faq.Title}" FontSize="17" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource Help.Faq.Intro}" Foreground="#64748B" FontSize="12" Margin="0,0,0,14" TextWrapping="Wrap"/>

                    <Expander Header="{DynamicResource Help.Faq1.Q}">
                        <TextBlock Text="{DynamicResource Help.Faq1.A}" TextWrapping="Wrap" Foreground="#475569" FontSize="13" LineHeight="21" Margin="4,8,0,4"/>
                    </Expander>
                    <Expander Header="{DynamicResource Help.Faq2.Q}">
                        <TextBlock Text="{DynamicResource Help.Faq2.A}" TextWrapping="Wrap" Foreground="#475569" FontSize="13" LineHeight="21" Margin="4,8,0,4"/>
                    </Expander>
                    <Expander Header="{DynamicResource Help.Faq3.Q}">
                        <TextBlock Text="{DynamicResource Help.Faq3.A}" TextWrapping="Wrap" Foreground="#475569" FontSize="13" LineHeight="21" Margin="4,8,0,4"/>
                    </Expander>
                    <Expander Header="{DynamicResource Help.Faq4.Q}">
                        <TextBlock Text="{DynamicResource Help.Faq4.A}" TextWrapping="Wrap" Foreground="#475569" FontSize="13" LineHeight="21" Margin="4,8,0,4"/>
                    </Expander>
                </StackPanel>
            </Border>

            <!-- Vidéos -->
            <Border Style="{StaticResource HelpCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="4" Height="22" CornerRadius="2" Background="#EA580C" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="{DynamicResource Help.Videos.Title}" FontSize="17" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource Help.Videos.Body}" TextWrapping="Wrap" Foreground="#475569" FontSize="13" LineHeight="21" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding OpenAccountVideoCommand}"
                                Style="{StaticResource HelpSecondaryButton}"
                                Padding="12"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="{Binding AccountVideoIcon}" Width="34" Height="34" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Tutoriel vidéo"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#1E3A8A"/>
                                    <TextBlock Text="Accéder à son compte client"
                                               TextWrapping="Wrap"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding OpenInstallVideoCommand}"
                                Style="{StaticResource HelpSecondaryButton}"
                                Padding="12"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="{Binding InstallVideoIcon}" Width="34" Height="34" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Tutoriel vidéo"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#1E3A8A"/>
                                    <TextBlock Text="Installer une nouvelle version"
                                               TextWrapping="Wrap"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
