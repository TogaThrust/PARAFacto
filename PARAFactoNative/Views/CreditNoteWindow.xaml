<Window x:Class="PARAFactoNative.Views.CreditNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Note de crédit" Height="260" Width="620" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource DialogCaptionTextBlock}"
                   Text="Créer une note de crédit"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DialogFieldLabelTextBlock}" Margin="0,10,8,0" Text="Pièce de référence :"/>
        <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,10,0,0"
                  ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}" DisplayMemberPath="Label"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DialogFieldLabelTextBlock}" Margin="0,10,8,0" Text="Montant (€) :"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Width="120" HorizontalAlignment="Left"
                 Text="{Binding AmountEuroText, UpdateSourceTrigger=PropertyChanged}"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource DialogChoiceButton}" Margin="0,0,8,0" Content="Annuler" IsCancel="True"/>
            <Button Style="{StaticResource DialogPrimaryChoiceButton}" Content="Valider" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
