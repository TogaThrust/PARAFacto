<Window x:Class="PARAFactoNative.Views.LunchVsAppointmentConflictWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agenda — conflit lunch / rendez-vous"
        Height="240" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="MessageText" Style="{StaticResource DialogMessageTextBlock}"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="LunchBtn" Content="Modifier le lunch" Style="{StaticResource DialogChoiceButton}" MinWidth="160" Margin="0,0,8,0" Click="LunchBtn_Click"/>
            <Button x:Name="RdvBtn" Content="Déplacer le rendez-vous" Style="{StaticResource DialogPrimaryChoiceButton}" MinWidth="200" IsDefault="True" Click="RdvBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
