<Window x:Class="PARAFactoNative.Views.PatientInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Informations patient" Height="520" Width="760"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource DialogCaptionTextBlock}" FontSize="15" Text="Informations patient"/>

        <ScrollViewer Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource DialogFormScrollViewer}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="NOM"/>
                    <TextBox x:Name="TbLastName" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" TextChanged="NameFields_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="PRÉNOM"/>
                    <TextBox x:Name="TbFirstName" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" TextChanged="NameFields_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10" Width="90">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="CODE"/>
                    <TextBox x:Name="TbCode3" Text="{Binding Code3, UpdateSourceTrigger=PropertyChanged}" MaxLength="3" TextChanged="Code3_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="NUMÉRO"/>
                    <TextBox Text="{Binding Numero, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="RUE"/>
                    <TextBox Text="{Binding Rue, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="CP"/>
                    <TextBox Text="{Binding Zip, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="VILLE"/>
                    <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="PAYS"/>
                    <TextBox Text="{Binding Country, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="RÉFÉREND"/>
                    <TextBox Text="{Binding Referend, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="EMAIL"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3">
                    <TextBlock Style="{StaticResource DialogFieldLabelTextBlock}" Text="TÉLÉPHONE"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Style="{StaticResource DialogChoiceButton}" Margin="0,0,8,0" Content="Annuler" IsCancel="True"/>
            <Button Style="{StaticResource DialogPrimaryChoiceButton}" Content="Enregistrer" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
