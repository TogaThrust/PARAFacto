<Window x:Class="PARAFactoNative.Views.AppointmentRelocateSlotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Déplacer le rendez-vous"
        Height="420" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="PatientLine" Style="{StaticResource DialogCaptionTextBlock}" TextWrapping="Wrap"/>
        <TextBlock x:Name="CurrentSlotLine" Grid.Row="1" Margin="0,8,0,0" Style="{StaticResource DialogMessageTextBlock}"/>
        <StackPanel Grid.Row="2" Margin="0,14,0,6">
            <TextBlock Style="{StaticResource DialogSectionHeaderTextBlock}" Text="Créneaux disponibles"/>
            <TextBlock Margin="0,4,0,0" Style="{StaticResource DialogMutedLabelTextBlock}" TextWrapping="Wrap"
                       Text="Les plages en vert sont des créneaux libres (comme dans l’agenda)."/>
        </StackPanel>
        <ListBox x:Name="SlotsList" Grid.Row="3" MinHeight="180"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Background="#F1F5F9"
                 BorderBrush="#CBD5E1"
                 BorderThickness="1"
                 SelectionChanged="SlotsList_OnSelectionChanged">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="6,3"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="OuterBd" Background="Transparent" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="OuterBd" Property="Background" Value="#BFDBFE"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="False"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="OuterBd" Property="Background" Value="#E0F2FE"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#DCFCE7" BorderBrush="#86EFAC" BorderThickness="1" CornerRadius="5" Padding="10,8" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#166534" CornerRadius="3" Padding="6,3" Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="Libre" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Time}" FontWeight="Bold" FontSize="15" Foreground="#14532D"/>
                                <TextBlock Text="Créneau disponible" FontSize="11" Foreground="#166534" Margin="0,2,0,0" Opacity="0.92"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <TextBlock Grid.Row="4" Margin="0,12,0,0" Style="{StaticResource DialogSectionHeaderTextBlock}" Text="Prévenir la personne responsable au :"/>
        <TextBlock x:Name="PhoneLine" Grid.Row="5" Margin="0,4,0,0" Style="{StaticResource DialogReadOnlyValueTextBlock}" FontWeight="SemiBold"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource DialogChoiceButton}" Margin="0,0,8,0" Content="Annuler" IsCancel="True"/>
            <Button x:Name="OkBtn" Style="{StaticResource DialogPrimaryChoiceButton}" Content="OK" IsDefault="True" IsEnabled="False" Click="OkBtn_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
