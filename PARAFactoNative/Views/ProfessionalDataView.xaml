<UserControl x:Class="PARAFactoNative.Views.ProfessionalDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <!-- Libellés en français : traduits par UiVisualLocalizer + UiTextTranslator (comme TarifsView, Console, etc.). -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="14">
            <TextBlock Text="Données professionnelles"
                       FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,14"
                       Text="Ces informations apparaissent sur les factures patients, notes de crédit, factures acquittées et états récapitulatifs mutuelles. Le logo et le titre sont aussi affichés dans la console."/>

            <WrapPanel Margin="0,0,0,12">
                <Button Content="Recharger depuis le disque" Command="{Binding Professional.ReloadCommand}" Padding="10,6" Margin="0,0,8,8"/>
                <Button Content="Enregistrer" Command="{Binding Professional.SaveCommand}" Padding="10,6" Margin="0,0,8,8"/>
            </WrapPanel>

            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,14" Background="#FAFAFA">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Logo (aperçu)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Border BorderBrush="#CCC" BorderThickness="1" Width="160" Height="160" Background="White">
                            <Image Source="{Binding Professional.LogoPreviewSource}"
                                   Stretch="Uniform"/>
                        </Border>
                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Choisir une image…" Command="{Binding Professional.PickLogoCommand}" Margin="0,0,8,8"/>
                            <Button Content="Retirer le logo" Command="{Binding Professional.ClearLogoCommand}" Margin="0,0,8,8"/>
                        </WrapPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Console — titre à côté du logo" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Professional.ConsoleHeaderTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <TextBlock Text="Factures / NC — nom ou titre du praticien (ligne principale)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Professional.InvoiceProviderName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <TextBlock Text="Rappels factures (signature WhatsApp / mail)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Professional.ReminderSenderDisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="Adresse et coordonnées (bloc facture patient)" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Adresse ligne 1" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Professional.AddressLine1, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Adresse ligne 2 (ex. CP Ville)" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Professional.AddressLine2, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="N° INAMI" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Professional.Inami, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="N° TVA" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Professional.VatNumber, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Téléphone" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Professional.Phone, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="E-mail" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Professional.Email, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
            </Grid>

            <TextBlock Text="Paiements (IBAN / BIC)" FontWeight="SemiBold" Margin="0,16,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="IBAN (factures patients / NC)" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Professional.Iban, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="IBAN (état mutuelle)" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Professional.IbanMutuelle, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="IBAN (notes de crédit — optionnel)" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Professional.IbanCreditNote, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="BIC" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Professional.Bic, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
            </Grid>

            <TextBlock Text="État récapitulatif mutuelle" FontWeight="SemiBold" Margin="0,16,0,8"/>
            <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="12" Margin="0,0,0,8"
                       Text="Ligne « Nom et prénom du prestataire » et adresse complète sur une seule ligne. Si l&#x2019;adresse dédiée est vide, les lignes 1 et 2 ci-dessus sont combinées."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nom et prénom (ex. DUPONT Jean)" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Professional.MutualRecapProviderName, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Adresse (une ligne, optionnel)" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Professional.MutualRecapAddressLine, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
