<Window x:Class="PARAFactoNative.Views.SubscriptionGateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PARAFacto Native — Abonnement"
        Width="520"
        MinWidth="440"
        SizeToContent="Height"
        MinHeight="220"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <TextBlock x:Name="BodyText"
                   Grid.Row="1"
                   Style="{StaticResource DialogMessageTextBlock}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Opacity="0.85">
                <Run Text="Identifiant d'activation (cus_…) : saisie masquée. Vous pouvez "/>
                <Run FontWeight="SemiBold" Text="coller"/>
                <Run Text=" depuis l'e-mail ; l'identifiant n'apparaît pas à l'écran et n'est pas lisible par copie depuis ce champ."/>
            </TextBlock>
            <PasswordBox x:Name="CustomerIdPasswordBox"
                         FontFamily="Consolas"
                         Padding="8,6"/>
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="PaymentButton"
                    Content="Page de paiement"
                    Style="{StaticResource DialogChoiceButton}"
                    Margin="0,0,8,0"
                    Click="Payment_OnClick"/>
            <Button x:Name="SaveButton"
                    Content="Enregistrer et vérifier"
                    Style="{StaticResource DialogPrimaryChoiceButton}"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Save_OnClick"/>
            <Button x:Name="QuitButton"
                    Content="Quitter"
                    Style="{StaticResource DialogChoiceButton}"
                    IsCancel="True"
                    Click="Quit_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
