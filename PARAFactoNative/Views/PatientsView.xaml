<UserControl x:Class="PARAFactoNative.Views.PatientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1100">

    <DockPanel Margin="10">

        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">

            <Separator Width="18" Opacity="0" />

            <Button Content="Nouveau"
                    Command="{Binding NewCommand}"
                    Padding="10,6" />

            <Button Content="Modifier"
                    Command="{Binding EditCommand}"
                    Padding="10,6"
                    Margin="8,0,0,0" />

            <Button Content="Supprimer patient"
                    Command="{Binding DeletePatientCommand}"
                    Padding="10,6"
                    Margin="8,0,0,0"
                    ToolTip="Uniquement si aucune séance n'a été enregistrée pour ce patient." />

            <TextBox Width="260"
                     Margin="18,0,0,0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding CountLabel}" />
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" EnableColumnVirtualization="False"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding Code3}" Width="Auto" />
                    <DataGridTextColumn Header="Nom" Binding="{Binding LastName}" Width="Auto" />
                    <DataGridTextColumn Header="Prénom" Binding="{Binding FirstName}" Width="Auto" />
                    <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="Auto" />
                    <DataGridTextColumn Header="Mutuelle" Binding="{Binding MutualName}" Width="Auto" />
                    <DataGridTextColumn Header="NISS" Binding="{Binding Niss}" Width="Auto" />
                    <DataGridTextColumn Header="Adresse" Binding="{Binding Address1}" Width="Auto" />
                    <DataGridTextColumn Header="CP" Binding="{Binding Zip}" Width="Auto" />
                    <DataGridTextColumn Header="Ville" Binding="{Binding City}" Width="Auto" />
                    <DataGridTextColumn Header="Pays" Binding="{Binding Country}" Width="Auto" />
                    <DataGridTextColumn Header="Téléphone" Binding="{Binding Phone}" Width="Auto" />
                    <DataGridTextColumn Header="Mail" Binding="{Binding Email}" Width="Auto" />
                    <DataGridTextColumn Header="Référent" Binding="{Binding Referend}" Width="Auto" />
                    <DataGridTextColumn Header="Médecin" Binding="{Binding PrescriberLastName}" Width="Auto" />
                    <DataGridTextColumn Header="Prénom médecin" Binding="{Binding PrescriberFirstName}" Width="Auto" />
                    <DataGridTextColumn Header="Code médecin" Binding="{Binding PrescriberCode}" Width="Auto" />
                    <DataGridTextColumn Header="Date presc" Binding="{Binding DatePrescription}" Width="Auto" />
                    <DataGridTextColumn Header="Date accord" Binding="{Binding DateAccord}" Width="Auto" />
                    <DataGridTextColumn Header="Période accord" Binding="{Binding PeriodeAccord}" Width="Auto" />
                    <DataGridTextColumn Header="Nomenclature" Binding="{Binding Nomenclature}" Width="Auto" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Margin="10,0,0,0">

                <DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">

                        <StackPanel>
                            <TextBlock FontSize="16"
                                       FontWeight="Bold"
                                       Text="Fiche patient" />

                            <TextBlock Margin="0,2,0,10"
                                       Foreground="#666"
                                       Text="Un clic sur une ligne charge directement la fiche. Le bouton Modifier enregistre les changements du patient sélectionné."
                                       TextWrapping="Wrap" />

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Nom:" />
                                <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}"
                                         TabIndex="0" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Prénom:" />
                                <TextBox Text="{Binding Prenom, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}"
                                         TabIndex="1" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Code 3:" />
                                <TextBox Text="{Binding Code3, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsCode3ReadOnly}"
                                         TabIndex="2" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Tarif RDV:" />
                                <ComboBox IsEnabled="{Binding IsEditing}"
                                          ItemsSource="{Binding StatutChoices}"
                                          SelectedItem="{Binding Statut, UpdateSourceTrigger=PropertyChanged}"
                                          Width="170" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Mutuelle:" />
                                <TextBox Text="{Binding Mutuelle, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="NISS:" />
                                <TextBox Text="{Binding Niss, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <Separator Margin="0,10,0,10" />

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Rue:" />
                                <TextBox Text="{Binding Rue, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Numéro:" />
                                <TextBox Text="{Binding Numero, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}"
                                         Width="120" />
                                <TextBlock Width="60"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="Pays:" />
                                <TextBox Text="{Binding Pays, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Adresse:" />
                                <TextBox Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="CP:" />
                                <TextBox Text="{Binding CodePostal, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}"
                                         Width="90" />
                                <TextBlock Width="45"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="Ville:" />
                                <TextBox Text="{Binding Ville, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Référent:" />
                                <TextBox Text="{Binding Referend, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Tél:" />
                                <TextBox Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Mail:" />
                                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <Separator Margin="0,10,0,10" />

                            <TextBlock FontWeight="Bold"
                                       Text="Infos médicales"
                                       Margin="0,0,0,6" />

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Nom médecin:" />
                                <TextBox Text="{Binding PrescriberLastName, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Prénom médecin:" />
                                <TextBox Text="{Binding PrescriberFirstName, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Code médecin:" />
                                <TextBox Text="{Binding PrescriberCode, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Date presc:" />
                                <TextBox Text="{Binding DatePrescription, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Date accord:" />
                                <TextBox Text="{Binding DateAccord, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Période accord:" />
                                <TextBox Text="{Binding PeriodeAccord, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Width="110" VerticalAlignment="Center" Text="Nomenclature:" />
                                <TextBox Text="{Binding Nomenclature, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}" />
                            </DockPanel>

                            <TextBlock Margin="0,8,0,4" FontWeight="Bold" Text="Commentaire patient" />
                            <TextBox Text="{Binding Commentaire, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsReadOnly}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinLines="8"
                                     VerticalScrollBarVisibility="Auto" />

                            <Separator Margin="0,12,0,10" />

                            <WrapPanel>
                                <Button Content="Enregistrer"
                                        Command="{Binding SaveCommand}"
                                        Padding="12,6" />
                                <Button Content="Annuler"
                                        Command="{Binding CancelCommand}"
                                        Padding="12,6"
                                        Margin="8,0,0,0" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>