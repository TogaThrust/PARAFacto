<Window x:Class="PARAFactoNative.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paiement" Height="240" Width="520" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource DialogCaptionTextBlock}"
                   Text="Enregistrer un paiement"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DialogFieldLabelTextBlock}" Margin="0,10,8,0" Text="Facture :"/>
        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DialogReadOnlyValueTextBlock}" Margin="0,10,0,0"
                   Text="{Binding InvoiceLabel}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DialogFieldLabelTextBlock}" Margin="0,10,8,0" Text="Montant (€) :"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Width="120" HorizontalAlignment="Left"
                 Text="{Binding AmountEuroText, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DialogFieldLabelTextBlock}" Margin="0,10,8,0" Text="Méthode :"/>
        <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Width="180" HorizontalAlignment="Left"
                  ItemsSource="{Binding Methods}" SelectedItem="{Binding SelectedMethod}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DialogFieldLabelTextBlock}" Margin="0,10,8,0" Text="Référence :"/>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Width="240" HorizontalAlignment="Left"
                 Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource DialogChoiceButton}" Margin="0,0,8,0" Content="Annuler" IsCancel="True"/>
            <Button Style="{StaticResource DialogPrimaryChoiceButton}" Content="Valider" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
