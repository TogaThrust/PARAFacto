<Window x:Class="PARAFactoNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:PARAFactoNative.Views"
        mc:Ignorable="d"
        Height="820" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <views:BoolToCheckmarkConverter x:Key="BoolToCheckmark"/>

        <Style x:Key="CheckmarkCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ConsoleActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="150"/>
        </Style>

        <Style x:Key="ConsoleUpdatePulseButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#B91C1C"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                            To="#FFFFFF"
                                            Duration="0:0:0.75"/>
                            <ColorAnimation Storyboard.TargetProperty="(Button.Foreground).(SolidColorBrush.Color)"
                                            To="#B91C1C"
                                            Duration="0:0:0.75"/>
                            <ColorAnimation Storyboard.TargetProperty="(Button.BorderBrush).(SolidColorBrush.Color)"
                                            To="#B91C1C"
                                            Duration="0:0:0.75"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl x:Name="MainTabControl"
                    SelectionChanged="MainTabControl_SelectionChanged">
            <TabItem Header="{DynamicResource Tab.Console}">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#DDD" BorderThickness="1" Padding="10" CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Text="Patient" Margin="0,0,0,8"/>
                            <DockPanel Grid.Row="1">
                                <TextBlock VerticalAlignment="Center" Text="Recherche:" Width="80"/>
                                <TextBox Text="{Binding Console.PatientSearch, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <ListBox Grid.Row="2"
                                     Margin="0,8,0,0"
                                     ItemsSource="{Binding Console.PatientResults}"
                                     SelectedItem="{Binding Console.SelectedPatient}"
                                     DisplayMemberPath="Display" />

                            <Separator Grid.Row="3" Margin="0,8,0,8"/>

                            <DockPanel Grid.Row="4">
                                <TextBlock VerticalAlignment="Center" Text="Code:" Width="80"/>
                                <TextBox Text="{Binding Console.SelectedPatient.Code3, Mode=OneWay}" IsReadOnly="True"/>
                            </DockPanel>
                            <DockPanel Grid.Row="5">
                                <TextBlock VerticalAlignment="Center" Text="Nom:" Width="80"/>
                                <TextBox Text="{Binding Console.SelectedPatient.LastName, Mode=OneWay}" IsReadOnly="True"/>
                            </DockPanel>
                            <DockPanel Grid.Row="6">
                                <TextBlock VerticalAlignment="Center" Text="Prénom:" Width="80"/>
                                <TextBox Text="{Binding Console.SelectedPatient.FirstName, Mode=OneWay}" IsReadOnly="True"/>
                            </DockPanel>
                            <DockPanel Grid.Row="7">
                                <TextBlock VerticalAlignment="Center" Text="Statut:" Width="80"/>
                                <TextBox Text="{Binding Console.SelectedPatient.Statut, Mode=OneWay}" IsReadOnly="True"/>
                            </DockPanel>
                            <DockPanel Grid.Row="8">
                                <TextBlock VerticalAlignment="Center" Text="Mutuelle:" Width="80"/>
                                <TextBox Text="{Binding Console.SelectedPatient.MutualName, Mode=OneWay}" IsReadOnly="True"/>
                            </DockPanel>

                            <WrapPanel Grid.Row="9" Margin="0,10,0,0">
                                <Button Content="Nouveau patient" Command="{Binding Console.NewPatientCommand}"/>
                                <Button Content="Modifier" Command="{Binding Console.EditPatientCommand}"/>
                                <Button Content="Supprimer patient" Margin="8,0,0,0"
                                        Command="{Binding Console.DeletePatientCommand}"
                                        ToolTip="Uniquement si aucune séance n'a été enregistrée pour ce patient."/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" Padding="10,2,10,10" CornerRadius="6" Margin="10,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Logo cabinet + titre ; logo ByTT collé en haut à droite, langues juste en dessous -->
                            <Grid Grid.Row="0" Margin="0,0,0,0" VerticalAlignment="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0"
                                       Width="140"
                                       Height="140"
                                       Margin="0,0,12,0"
                                       Stretch="Uniform"
                                       VerticalAlignment="Top"
                                       IsHitTestVisible="False"
                                       Source="{Binding Console.InvoiceLogoSource}"/>
                                <TextBlock Grid.Column="1"
                                           MinWidth="0"
                                           Margin="0,0,18,0"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Text="{Binding Console.ConsoleHeaderTitle}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="2"
                                            Orientation="Vertical"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,0,0,0">
                                    <Image MaxWidth="280"
                                           MaxHeight="96"
                                           Width="Auto"
                                           Height="Auto"
                                           Margin="0,0,0,6"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Right"
                                           IsHitTestVisible="False"
                                           Source="{Binding Console.LogoSource}"/>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <Button x:Name="LangFrButton"
                                                Width="24"
                                                Height="18"
                                                Margin="0,0,4,0"
                                                Padding="0"
                                                ToolTip="{DynamicResource Language.TooltipFr}"
                                                Click="LangFrButton_OnClick">
                                            <Image Width="18" Height="12" Stretch="Fill" Source="Assets/french.jpg"/>
                                        </Button>
                                        <Button x:Name="LangEnButton"
                                                Width="24"
                                                Height="18"
                                                Margin="0,0,4,0"
                                                Padding="0"
                                                ToolTip="{DynamicResource Language.TooltipEn}"
                                                Click="LangEnButton_OnClick">
                                            <Image Width="18" Height="12" Stretch="Fill" Source="Assets/english.jpg"/>
                                        </Button>
                                        <Button x:Name="LangNlButton"
                                                Width="24"
                                                Height="18"
                                                Padding="0"
                                                ToolTip="{DynamicResource Language.TooltipNl}"
                                                Click="LangNlButton_OnClick">
                                            <Image Width="18" Height="12" Stretch="Fill" Source="Assets/dutch.jpg"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Encodage séance (logo byTT déplacé en Row 0) -->
                            <TextBlock Grid.Row="1" Margin="0,0,0,2" FontSize="16" FontWeight="Bold" Text="Encodage séance" VerticalAlignment="Center"/>

                            <WrapPanel Grid.Row="2">
                                <TextBlock VerticalAlignment="Center" Text="Date:" Width="60"/>
                                <DatePicker SelectedDate="{Binding Console.SeanceDate}" Width="140"/>
                                <TextBlock VerticalAlignment="Center" Text="Heure:" Margin="16,0,0,0"/>
                                <ComboBox Width="90"
                                          IsEditable="True"
                                          ItemsSource="{Binding Console.SeanceTimeSlots}"
                                          SelectedItem="{Binding Console.SeanceStartTime}"/>
                                <CheckBox Content="Cash cabinet (acquittée)" IsChecked="{Binding Console.IsCash}" Margin="20,0,0,0"/>
                            </WrapPanel>

                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Tarif:" Width="60"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Console.Tarifs}"
                                          SelectedItem="{Binding Console.SelectedTarif}"
                                          DisplayMemberPath="Label"
                                          Width="280"/>
                                <Button Grid.Column="3"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource ConsoleUpdatePulseButtonStyle}"
                                        Command="{Binding Console.OpenInstallerDownloadCommand}"
                                        Visibility="{Binding Console.IsUpdateAvailable, Converter={StaticResource BoolToVisibility}}"
                                        ToolTip="{DynamicResource Agenda.UpdateButton.Tooltip}">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="{DynamicResource Agenda.UpdateButton.Text}"/>
                                </Button>
                            </Grid>

                            <WrapPanel Grid.Row="4">
                                <TextBlock VerticalAlignment="Center" Text="Part patient:" Width="100"/>
                                <TextBlock VerticalAlignment="Center" Text="{Binding Console.SelectedTarif.PartPatientEuro}" FontWeight="Bold"/>
                                <TextBlock VerticalAlignment="Center" Text="   Part mutuelle:" Margin="20,0,0,0"/>
                                <TextBlock VerticalAlignment="Center" Text="{Binding Console.SelectedTarif.PartMutuelleEuro}" FontWeight="Bold"/>
                            </WrapPanel>

                            <TextBlock Grid.Row="5" Margin="0,8,0,0" Text="Commentaire"/>
                            <TextBox Grid.Row="6" Text="{Binding Console.SeanceNotes}" AcceptsReturn="True" Height="52" VerticalScrollBarVisibility="Auto"/>

                            <!-- Actions séances et Actions journalier côte à côte pour gagner en hauteur pour Séances du jour -->
                            <Grid Grid.Row="7" Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontWeight="Bold" Text="Actions séances" Margin="0,0,0,4"/>
                                    <WrapPanel>
                                        <Button Style="{StaticResource ConsoleActionButtonStyle}" MinWidth="130" Content="Ajouter séance" Command="{Binding Console.AddSeanceCommand}"/>
                                        <Button Style="{StaticResource ConsoleActionButtonStyle}" MinWidth="130" Content="Modifier la ligne" Command="{Binding Console.UpdateSeanceCommand}"/>
                                        <Button Style="{StaticResource ConsoleActionButtonStyle}" MinWidth="130" Content="Effacer la ligne" Command="{Binding Console.DeleteSeanceCommand}"/>
                                        <Button Style="{StaticResource ConsoleActionButtonStyle}" MinWidth="130" Content="ANNULATION"
                                                Command="{Binding Console.UndoCommand}"
                                                Visibility="{Binding Console.CanUndo, Converter={StaticResource BoolToVisibility}}"/>
                                    </WrapPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="Bold" Text="Actions journalier" Margin="0,0,0,4"/>
                                    <WrapPanel>
                                        <Button Style="{StaticResource ConsoleActionButtonStyle}" Content="Générer PDF journalier" Command="{Binding Console.ExportJournalierCommand}"/>
                                        <Button Style="{StaticResource ConsoleActionButtonStyle}" Content="Ouvrir dossier Journaliers" Command="{Binding Console.OpenWorkspaceFolderCommand}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="8" Margin="0,4,0,4" FontWeight="Bold" Text="Actions factures"/>
                            <Grid Grid.Row="9" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <WrapPanel Grid.Column="0">
                                    <Button Style="{StaticResource ConsoleActionButtonStyle}" Content="Générer factures patients" Command="{Binding Console.GeneratePatientInvoicesCommand}"/>
                                    <Button Style="{StaticResource ConsoleActionButtonStyle}" Content="Générer factures mutuelles" Command="{Binding Console.GenerateMutualRecapsCommand}"/>
                                    <Button Style="{StaticResource ConsoleActionButtonStyle}" Content="Ouvrir dossier factures patients du mois" MinWidth="280" Command="{Binding Console.OpenMonthFolderCommand}"/>
                                    <Button Style="{StaticResource ConsoleActionButtonStyle}" Content="Ouvrir dossier factures mutuelle du mois" MinWidth="280" Command="{Binding Console.OpenLastMutualMonthFolderCommand}"/>
                                    <Button Style="{StaticResource ConsoleActionButtonStyle}" Content="Réinitialiser la base + démo (SQL + patients / RDV)"
                                            Command="{Binding Console.FullDemoDatabaseResetCommand}"
                                            Visibility="{Binding Console.ShowLocalDemoDbTools, Converter={StaticResource BoolToVisibility}}"
                                            ToolTip="Supprime le fichier SQLite, recrée le schéma, tarifs et patients « -Démo », et l’agenda du mois courant. Effacez aussi vos dossiers PDF sur le disque si besoin. Code 7324."/>
                                    <Button Style="{StaticResource ConsoleActionButtonStyle}" Content="Purge hors patients démo (DB + journaliers)"
                                            Command="{Binding Console.PurgeNonDemoBillingCommand}"
                                            Visibility="{Binding Console.ShowLocalDemoDbTools, Converter={StaticResource BoolToVisibility}}"
                                            ToolTip="Supprime séances, factures patients/NC liées aux patients sans « -Démo » dans le nom, toutes les factures mutuelles, et les PDF ENCAISSEMENTS_*.pdf des journaliers. Code 7324."/>
                                </WrapPanel>
                            </Grid>

                            <!-- Tableau séances : hauteur max + défilement interne (petits écrans / console longue) -->
                            <Grid Grid.Row="10" Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Style="{StaticResource ConsoleActionButtonStyle}"
                                            Content="IMPORTER AGENDA"
                                            ToolTip="Importe les rendez-vous de l’agenda pour la date sélectionnée dans la console (passé ou futur) : une séance par RDV, avec la même date de séance."
                                            Command="{Binding Console.ImportAgendaCommand}"/>
                                    <TextBlock FontSize="14" FontWeight="Bold" Text="Séances du jour" VerticalAlignment="Center"/>
                                </DockPanel>
                                <!-- Pas de ScrollViewer autour du DataGrid : avec HorizontalScroll=Auto il mesure une largeur infinie,
                                     ce qui écrase les colonnes Auto et casse la colonne * (bande vide à droite). -->
                                <DataGrid Grid.Row="1"
                                          Margin="0,8,0,0"
                                          MaxHeight="320"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding Console.TodaySeances}"
                                          SelectedItem="{Binding Console.SelectedTodaySeance}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          EnableColumnVirtualization="False"
                                          HeadersVisibility="Column"
                                          MinWidth="280"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.CanContentScroll="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Code" Binding="{Binding Code3}" MinWidth="52" Width="Auto"/>
                                        <DataGridTextColumn Header="Com." Binding="{Binding HasComment, Converter={StaticResource BoolToCheckmark}}" MinWidth="44" Width="48" ElementStyle="{StaticResource CheckmarkCellStyle}"/>
                                        <DataGridTextColumn Header="Tarif" Binding="{Binding TarifLabel}" MinWidth="120" Width="*"/>
                                        <DataGridTextColumn Header="Cash" Binding="{Binding IsCash, Converter={StaticResource BoolToCheckmark}}" MinWidth="44" Width="48" ElementStyle="{StaticResource CheckmarkCellStyle}"/>
                                        <DataGridTextColumn Header="Part patient" Binding="{Binding PartPatientEuro}" MinWidth="96" Width="Auto"/>
                                        <DataGridTextColumn Header="Part mutuelle" Binding="{Binding PartMutuelleEuro}" MinWidth="108" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <Border Grid.Row="11" Margin="0,8,0,0" Padding="8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Cash patient :" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Console.CashPatientText}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Facturé patient :" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Console.FacturedPatientText}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Total tiers payant :" FontWeight="Bold" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Console.TotalTiersPayantText}" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Facturé mutuelle :" FontWeight="Bold" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Console.FacturedMutuelleText}" Margin="0,6,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Montant total du jour :" FontWeight="Bold" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Console.TotalDayText}" Margin="0,6,0,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource Tab.Patients}">
                <views:PatientsView DataContext="{Binding Patients}" />
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Tarifs}">
                <views:TarifsView />
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Seances}">
                <views:SeancesView />
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Factures}">
                <views:FacturesView />
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Agenda}">
                <views:AgendaView DataContext="{Binding Agenda}" />
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Support}">
                <views:HelpView DataContext="{Binding Help}" />
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Technical}">
                <ScrollViewer Margin="10"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <StackPanel>
                    <Border Margin="0,0,0,20"
                            Padding="14"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="#F8FAFC">
                        <StackPanel>
                            <TextBlock Text="Politique de confidentialité et conditions d'utilisation"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#B91C1C"
                                       FontSize="12"
                                       Margin="0,0,0,8"
                                       Text="{Binding Legal.DocumentsLoadError}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Legal.HasDocumentsError}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Politique de confidentialité (RGPD, mineurs, données de santé)"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,4"/>
                            <TextBox IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="160"
                                     MaxHeight="260"
                                     FontFamily="Segoe UI"
                                     FontSize="11"
                                     Text="{Binding Legal.PrivacyText, Mode=OneWay}"/>
                            <TextBlock Text="Conditions générales d'utilisation du service"
                                       FontWeight="SemiBold"
                                       Margin="0,12,0,4"/>
                            <TextBox IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="160"
                                     MaxHeight="260"
                                     FontFamily="Segoe UI"
                                     FontSize="11"
                                     Text="{Binding Legal.TermsText, Mode=OneWay}"/>
                            <CheckBox Margin="0,12,0,6"
                                      FontSize="13"
                                      Content="J'ai lu la politique de confidentialité et je l'accepte pour la version affichée ci-dessus."
                                      IsChecked="{Binding Legal.AcceptPrivacy, UpdateSourceTrigger=PropertyChanged}"/>
                            <CheckBox FontSize="13"
                                      Content="J'ai lu les conditions d'utilisation du service et je les accepte pour la version affichée ci-dessus."
                                      IsChecked="{Binding Legal.AcceptTerms, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Enregistrer mon acceptation (preuve locale)"
                                    Command="{Binding Legal.SaveAcceptanceCommand}"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Padding="14,8"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#475569"
                                       FontSize="12"
                                       Margin="0,12,0,0"
                                       Text="{Binding Legal.AcceptanceSummary}"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#64748B"
                                       FontSize="11"
                                       Margin="0,6,0,0">
                                <Run Text="Fichier d'audit des acceptations : "/>
                                <Run Text="{Binding Legal.AuditFilePath, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- DockPanel : panneau gauche largeur fixe (évite qu'il disparaisse avec certaines mesures de grille *). -->
                    <DockPanel LastChildFill="True"
                               MaxWidth="1180"
                               HorizontalAlignment="Left"
                               UseLayoutRounding="True">

                        <!-- Gauche : portail clients Stripe -->
                        <Border DockPanel.Dock="Left"
                                Width="380"
                                MinWidth="300"
                                Margin="0,0,24,0"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                Padding="16"
                                CornerRadius="6"
                                VerticalAlignment="Top"
                                Background="#FAFAFA">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Technical.Subscription.Title}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{DynamicResource Technical.Subscription.Subtitle}"
                                           FontSize="13"
                                           Foreground="#475569"
                                           Margin="0,0,0,12"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#334155"
                                           LineHeight="20"
                                           Margin="0,0,0,16"
                                           Text="Permet aux abonnés de gérer leur carte bancaire, leurs factures et leur abonnement (selon les options activées dans Stripe)."/>
                                <Button Content="{DynamicResource Technical.Subscription.OpenPortal}"
                                        Click="StripeCustomerPortal_Click"
                                        HorizontalAlignment="Stretch"
                                        Padding="18,10"
                                        MinHeight="40"
                                        FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- Droite : e-mail et SMTP -->
                        <Border MinWidth="360"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                Padding="12"
                                CornerRadius="6"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Email d'envoi de sauvegarde des fichiers journaliers et factures"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Email :" Margin="0,0,10,0"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Console.RecipientEmail, UpdateSourceTrigger=PropertyChanged}"
                                             HorizontalContentAlignment="Left"
                                             TextAlignment="Left"/>
                                </Grid>

                                <CheckBox Content="Utiliser SMTP (Gmail/Autre) si Outlook absent"
                                          IsChecked="{Binding Console.UseSmtp}"
                                          Margin="0,12,0,0"/>

                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Console.UseSmtp}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="SMTP host :" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Console.SmtpHost, UpdateSourceTrigger=PropertyChanged}"
                                                 HorizontalContentAlignment="Left"
                                                 TextAlignment="Left"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Port :" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Console.SmtpPort, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="90"
                                                 HorizontalContentAlignment="Left"
                                                 TextAlignment="Left"/>
                                        <CheckBox Grid.Column="2" Content="SSL/TLS" IsChecked="{Binding Console.SmtpEnableSsl}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Utilisateur :" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Console.SmtpUsername, UpdateSourceTrigger=PropertyChanged}"
                                                 HorizontalContentAlignment="Left"
                                                 TextAlignment="Left"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="From (optionnel) :" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Console.SmtpFromEmail, UpdateSourceTrigger=PropertyChanged}"
                                                 HorizontalContentAlignment="Left"
                                                 TextAlignment="Left"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Technical.Smtp.AppPassword}" Margin="0,0,10,0"/>
                                        <PasswordBox Grid.Column="1"
                                                     views:PasswordBoxAssistant.BindPassword="True"
                                                     views:PasswordBoxAssistant.BoundPassword="{Binding Console.SmtpPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Professional}">
                <views:ProfessionalDataView />
            </TabItem>
        </TabControl>

        <!-- Blocage jusqu'à acceptation des documents juridiques (versions courantes) -->
        <Border Background="#CC1E293B"
                Panel.ZIndex="1000"
                Visibility="{Binding Legal.ShowBlockingOverlay, Converter={StaticResource BoolToVisibility}}">
            <Border VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="White"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="24"
                    MaxWidth="520"
                    Margin="24">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="15"
                               LineHeight="22"
                               Text="{Binding Legal.LegalGateMessage}"/>
                    <Button Content="Ouvrir l'onglet Données techniques"
                            Margin="0,20,0,0"
                            Padding="16,10"
                            HorizontalAlignment="Stretch"
                            FontSize="14"
                            Command="{Binding Legal.OpenTechnicalTabCommand}"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
